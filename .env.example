# ============================================================
# ADP — Environment Variables Template
# Copy to .env and fill in secrets. Never commit .env to git.
# ============================================================

# PostgreSQL — Supabase (use postgresql+asyncpg:// for runtime)
# Project URL: https://ftzxurbxqqaxcmgsbtbv.supabase.co
DATABASE_URL=postgresql+asyncpg://postgres:<YOUR_DB_PASSWORD>@db.ftzxurbxqqaxcmgsbtbv.supabase.co:5432/postgres

# Alembic needs sync URL (psycopg2). alembic/env.py auto-converts.
# You can leave DATABASE_URL as asyncpg — env.py strips the driver.

# LLM API Keys (ADR-002)
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
OPENAI_API_KEY=sk-...

# LiteLLM
LITELLM_MASTER_KEY=sk-...

# Application
SQL_ECHO=false
APP_ENV=development
